# Config file for weather module
# Here we define the archetypes that,
# when present, are cause for avoiding adding
# weather effects to a given space.
#
# File format is as follows:
# - archetype name
# - 0 if not a weather effect, 1 if it is
#   Weather effects have some additional processing
#   for cleaning up stuff

snow, 1
snow2, 1
snow3, 1
snow4, 1
snow5, 1
mountain1_snow, 1
mountain2_snow, 1
rain1_weather, 1
rain2_weather, 1
rain3_weather, 1
rain4_weather, 1
rain5_weather, 1
mountain1_rivlets_weather, 1
mountain2_rivlets_weather, 1
ipond, 1
